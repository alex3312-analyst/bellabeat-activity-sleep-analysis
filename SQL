CREATE TABLE SleepDaily AS
SELECT 
    user_id,
    date_sleep,
    SUM(CASE WHEN value = 1 THEN 1 ELSE 0 END) AS minutes_asleep,
    SUM(CASE WHEN value = 2 THEN 1 ELSE 0 END) AS minutes_restless,
    SUM(CASE WHEN value = 3 THEN 1 ELSE 0 END) AS minutes_awake,
    COUNT(*) AS total_minutes_in_bed
FROM Sleep
GROUP BY user_id, date_sleep;

SELECT *
FROM SleepDaily
ORDER BY user_id, date_sleep
LIMIT 20;

SELECT 
    MIN(date_sleep) AS primer_dia,
    MAX(date_sleep) AS ultimo_dia,
    COUNT(*) AS total_registros
FROM SleepDaily;

SELECT *
FROM SleepDaily
ORDER BY total_minutes_in_bed DESC
LIMIT 10;

CREATE TABLE SleepActivity AS
SELECT
	a.user_id,
    a.activity_date AS date,
    a.total_steps,
    a.total_distance,
    a.calories,
    s.minutes_asleep,
    s.minutes_restless,
    s.minutes_awake,
    s.total_minutes_in_bed
FROM dailyActivity a
INNER JOIN SleepDaily s
	on a.user_id = s.user_id
    AND a.activity_date = s.date_sleep;

